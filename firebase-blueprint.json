{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "number" },
        "pin": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "balance": { "type": "number" },
        "lastUpdated": { "type": "number" },
        "ownerUid": { "type": "string" }
      },
      "required": ["id", "name", "ownerUid"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Transaction record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["CREDIT", "PAYMENT"] },
        "note": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "createdAt": { "type": "number" },
        "ownerUid": { "type": "string" }
      },
      "required": ["id", "customerId", "amount", "type", "date", "ownerUid"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Customer records"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Transaction records"
    }
  }
}
